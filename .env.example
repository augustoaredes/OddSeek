# Database (Neon Postgres via Vercel Marketplace)
DATABASE_URL=postgres://user:pass@host/db

# Cache (Upstash Redis via Vercel Marketplace)
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Auth.js v5
AUTH_SECRET=run-openssl-rand-base64-32-here
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# OddSeek
ODDSEEK_DATA_SOURCE=mock
ODDSEEK_DEFAULT_CURRENCY=BRL

# The Odds API — https://the-odds-api.com
# Quando definida, a página /odds usa dados reais (cache Redis 5 min).
# Sem a key, usa mock data automaticamente.
THE_ODDS_API_KEY=your_key_here
